^\.git$
^\.github$
^\.gitignore$
^\.lintr$
^\.Rproj\.user$
^.*\.Rproj$
^.*\.Rcheck$

# Dev-only docs and planning (in git, not in the package tarball)
^docs$
^PLAN\.md$
^CONTRIBUTING\.md$
^HANDOFF\.md$
^AGENTS\.md$
^CLAUDE\.md$
^README\.Rmd$
^cran-comments\.md$

# Agent runtime caches
^\.agents$
^\.claude$
^\.codex$
^skills-lock\.json$

# Frontend tooling for the dev-time CSS build
^components\.json$
^package\.json$
^package-lock\.json$
^node_modules$
^tsconfig\.json$
^\.tool-versions$
^Makefile$
^tools$

# Tailwind source — only the compiled output ships
^inst/www/src$

# pkgdown
^_pkgdown\.yml$
^pkgdown$
^site$

# Component gallery — Quarto-rendered, dev-only. See ADR 0013.
# Holds .qmd pages, _extensions/ shinylive, and _quarto.yml.
^vignettes/articles$

# CI
^\.github$
