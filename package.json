{
  "name": "shinyblocks-build",
  "private": true,
  "type": "module",
  "description": "Maintainer-only frontend build pipeline for shinyblocks. End users do not need Node.",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "build": "npm run build:css && npm run build:runtime",
    "build:css": "tailwindcss --input inst/www/src/shinyblocks.css --output inst/www/shinyblocks.css --minify",
    "build:runtime": "vite build --config frontend/vite.config.js && node tools/build-runtime.mjs",
    "watch:css": "tailwindcss --input inst/www/src/shinyblocks.css --output inst/www/shinyblocks.css --watch",
    "build:icons": "node tools/build-icons.mjs",
    "test:runtime": "node tools/runtime-smoke.mjs && npm run test:select-overflow",
    "test:select-overflow": "node tools/select-overflow-smoke.mjs",
    "test:runtime-shiny": "node tools/runtime-shiny-smoke.mjs",
    "test:showcase": "node tools/showcase-smoke.mjs",
    "test:themes": "npm run test:themes-static && npm run test:themes-runtime && npm run test:style-parity",
    "test:themes-browser": "npm run test:themes-runtime && npm run test:style-parity",
    "test:themes-static": "node tools/theme/check-token-usage.mjs",
    "test:themes-drift": "node tools/theme/check-default-token-drift.mjs",
    "test:themes-runtime": "node tools/theme/check-theme-response.mjs",
    "test:style-parity": "node tools/theme/check-style-parity.mjs",
    "test:style-leanness": "node tools/theme/check-style-leanness.mjs",
    "shadcn:info": "npx shadcn@latest info --json",
    "shadcn:docs": "npx shadcn@latest docs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "lucide-static": "^1.14.0",
    "playwright": "^1.59.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.2.4",
    "vite": "^8.0.12"
  }
}
